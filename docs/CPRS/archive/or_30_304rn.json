      "children": [],
      "content_layer": "body",
      "meta": null,
      "label": "text",
      "prov": [],
      "orig": "Third, developers changed CPRS to detect when the user switches patients and the FTimedOut variable is set to TRUE. When this condition exists, CPRS displays an error message and will shut down. Listed below is the error message:",
      "text": "Third, developers changed CPRS to detect when the user switches patients and the FTimedOut variable is set to TRUE. When this condition exists, CPRS displays an error message and will shut down. Listed below is the error message:",
      "formatting": {
        "bold": false,
        "italic": false,
        "underline": false,
        "strikethrough": false,
        "script": "baseline"
      },
      "hyperlink": null
    },
    {
      "self_ref": "#/texts/49",
