      "children": [],
      "content_layer": "body",
      "meta": null,
      "label": "text",
      "prov": [],
      "orig": "“CPRS has encountered a serious problem and is unable to display the selected patient’s data.  This is a known issue documented in PSPO 1089.  To prevent patient safety issues, CPRS is shutting down. Shutting down and then restarting CPRS will correct the problem, and you may continue working in CPRS.",
      "text": "“CPRS has encountered a serious problem and is unable to display the selected patient’s data.  This is a known issue documented in PSPO 1089.  To prevent patient safety issues, CPRS is shutting down. Shutting down and then restarting CPRS will correct the problem, and you may continue working in CPRS.",
      "formatting": {
        "bold": false,
        "italic": false,
        "underline": false,
        "strikethrough": false,
        "script": "baseline"
      },
      "hyperlink": null
