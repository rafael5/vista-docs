      "label": "text",
      "prov": [],
      "orig": "CPRS GUI version 27 requires Internet Explorer 4.0 (IE4) or later. However, PKI functionality requires IE 5.5 or later with 128-bit encryption.",
      "text": "CPRS GUI version 27 requires Internet Explorer 4.0 (IE4) or later. However, PKI functionality requires IE 5.5 or later with 128-bit encryption.",
      "formatting": {
        "bold": false,
        "italic": false,
        "underline": false,
